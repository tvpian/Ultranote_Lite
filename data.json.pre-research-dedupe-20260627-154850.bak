    {
      "id": "igen8e3w",
      "title": "Automated Data Collection Pipeline Setup",
      "content": "# Isaac Sim / Omniverse Kit Script Editor\nfrom pxr import Usd, UsdGeom, Gf, Sdf\nimport omni.usd\n\n# ─── Global configurable variables ───\nQUAD_COLORS = {\n    \"TL\": (1.0, 1.0, 1.0),   # top-left: white\n   \"TR1\": (0.0, 1.0, 0.0),   # top-right: green\n    \"BL\": (1.0, 1.0, 0.0),   # bottom-left: yellow\n    \"BR\": (1.0, 0.0, 0.0),    # bottom-right: red\n        # additional:\n    \"TR\": (0.0, 0.0, 1.0),   # blue\n    \"Extra2\": (1.0, 0.647, 0.0), # orange\n    \"Extra3\": (0.0, 0.0, 0.0),   # black\n}\n\n# Board dimensions:\nBOARD_WIDTH  = 0.40   # in meters (40 cm)\nBOARD_DEPTH  = 0.20   # in meters (20 cm)\nBOARD_THICKNESS = 0.005  # in meters (5 mm)\nZ_BASE = 0.0  # height of board bottom from world origin\n\n# ─── Helper functions ───\ndef _get_stage():\n    ctx = omni.usd.get_context()\n    if ctx is None:breakoing\n        raise RuntimeError(\"omni.usd context not available — are you in Isaac Sim Script Editor?\")\n    stage = ctx.get_stage()\n    if stage is None:\n        raise RuntimeError(\"USD stage not found/loaded.\")\n    return stage\n\ndef _define_xform(stage, path):\n    if not path.startswith(\"/\"):\n        path = \"/\" + path\n    return UsdGeom.Xform.Define(stage, Sdf.Path(path))\n\ndef _set_display_color(prim, rgb):\n    r, g, b = map(float, rgb)\n    UsdGeom.Gprim(prim).CreateDisplayColorAttr([Gf.Vec3f(r, g, b)])\n\ndef _xform_set_translate_scale(prim, t_xyz, s_xyz):\n    tx, ty, tz = map(float, t_xyz)\n    sx, sy, sz = map(float, s_xyz)\n    api = UsdGeom.XformCommonAPI(UsdGeom.Xformable(prim))\n    api.SetTranslate(Gf.Vec3d(tx, ty, tz))\n    api.SetScale(Gf.Vec3f(sx, sy, sz))\n\ndef _create_cube_quadrant(stage, parent_path, name, center_xyz, scale_xyz, color_rgb):\n    qpath = f\"{parent_path}/{name}\"\n    cube = UsdGeom.Cube.Define(stage, Sdf.Path(qpath))\n    cube.CreateSizeAttr(1.0)\n    _xform_set_translate_scale(cube.GetPrim(), center_xyz, scale_xyz)\n    _set_display_color(cube.GetPrim(), color_rgb)\n    return cube\n\n# ─── Main creation function ───\ndef create_quadrant_board(\n    root_path=\"/World\",\n    xform_name=\"QuadrantBoard\",\n    width=BOARD_WIDTH,\n    depth=BOARD_DEPTH,\n    thickness=BOARD_THICKNESS,\n    colors=QUAD_COLORS,\n    z_base=Z_BASE,\n    add_collision=False\n):\n    stage = _get_stage()\n    board_path = f\"{root_path.rstrip('/')}/{xform_name}\"\n    _define_xform(stage, board_path)\n\n    half_w = width * 0.5\n    half_d = depth * 0.5\n    quad_w = half_w\n    quad_d = half_d\n    z_center = float(z_base) + thickness * 0.5\n\n    # define centers (X,Y,Z) of 4 quadrants (TL, TR, BL, BR)\n    centers = {\n        \"TL\": (-quad_w * 0.5, +quad_d * 0.5, z_center),\n        \"TR\": (+quad_w * 0.5, +quad_d * 0.5, z_center),\n        \"BL\": (-quad_w * 0.5, -quad_d * 0.5, z_center),\n        \"BR\": (+quad_w * 0.5, -quad_d * 0.5, z_center),\n    }\n    names = {\n        \"TL\": \"Q_TL\",\n        \"TR\": \"Q_TR\",\n        \"BL\": \"Q_BL\",\n        \"BR\": \"Q_BR\",\n    }\n    scale = (quad_w, quad_d, thickness)\n\n    for key in (\"TL\",\"TR\",\"BL\",\"BR\"):\n        name  = names[key]\n        center = centers[key]\n        color = colors[key]\n        _create_cube_quadrant(stage, board_path, name, center, scale, color)\n\n    # skip saving the layer — user will save manually\n\n    print(f\"[QuadrantBoard] Created at {board_path} | total size = ({width} × {depth} × {thickness}) m\")\n    return board_path\n\n# ─── Run the creation ───\ncreate_quadrant_board(\n    xform_name=\"QuadrantBoard\"\n)\n",
      "tags": [],
      "projectId": "c7szb5bi",
      "dateIndex": null,
      "type": "note",
